<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="header-utility spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-padding', settings: section.settings %}; --utility-gap: {{ section.settings.item_gap }}px;"
>
  <div class="header-utility__inner">
    <div class="header-utility__links" role="list">
      {% for block in section.blocks %}
        {% if block.type == 'support_link' and block.settings.label != blank %}
          <div class="header-utility__item" role="listitem" {{ block.shopify_attributes }}>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="header-utility__link">
                {{ block.settings.label }}
              </a>
            {% else %}
              <span>{{ block.settings.label }}</span>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="header-utility__contact">
      {% if section.settings.email_text != blank %}
        <div class="header-utility__meta-item">
          <span class="svg-wrapper header-utility__meta-icon" aria-hidden="true">
            {{- 'icon-info.svg' | inline_asset_content -}}
          </span>
          {% if section.settings.email_link != blank %}
            <a href="{{ section.settings.email_link }}" class="header-utility__link">{{ section.settings.email_text }}</a>
          {% else %}
            <span>{{ section.settings.email_text }}</span>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.phone_text != blank %}
        <div class="header-utility__meta-item">
          <span class="svg-wrapper header-utility__meta-icon" aria-hidden="true">
            {{- 'icon-orders.svg' | inline_asset_content -}}
          </span>
          {% if section.settings.phone_link != blank %}
            <a href="{{ section.settings.phone_link }}" class="header-utility__link">{{ section.settings.phone_text }}</a>
          {% else %}
            <span>{{ section.settings.phone_text }}</span>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.locale_text != blank %}
        <div class="header-utility__meta-item">
          <span class="svg-wrapper header-utility__meta-icon" aria-hidden="true">
            {{- 'icon-cart.svg' | inline_asset_content -}}
          </span>
          <span>{{ section.settings.locale_text }}</span>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .header-utility {
    border-block-end: 1px solid var(--color-border);
    font-size: 0.78rem;
    background: rgb(var(--color-foreground-rgb) / 0.02);
    font-size: var(--font-size--2xs);
  }

  .header-utility__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--utility-gap);
    align-items: center;
  }

  .header-utility__links,
  .header-utility__contact {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    column-gap: var(--utility-gap);
    row-gap: 0.375rem;
  }

  .header-utility__item,
  .header-utility__meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.44rem;
    opacity: 0.92;
    line-height: 1.2;
  }

  .header-utility__meta-icon {
    width: 0.82rem;
    height: 0.82rem;
    opacity: 0.7;
    gap: 0.5rem;
    opacity: 0.9;
  }

  .header-utility__meta-icon {
    width: 0.875rem;
    height: 0.875rem;
    opacity: 0.75;
  }

  .header-utility__item:not(:last-child)::after,
  .header-utility__meta-item:not(:last-child)::after {
    content: '';
    width: 1px;
    height: 0.72rem;
    height: 0.875rem;
    background: rgb(var(--color-foreground-rgb) / 0.25);
  }

  .header-utility__link {
    color: inherit;
    text-decoration: none;
  }

  .header-utility__link:hover,
  .header-utility__link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  @media screen and (max-width: 989px) {
    .header-utility__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.45rem;
    }

    .header-utility__links,
    .header-utility__contact {
      width: 100%;
      overflow-x: auto;
      flex-wrap: nowrap;
      scrollbar-width: none;
      padding-bottom: 0.15rem;
    }

    .header-utility__links::-webkit-scrollbar,
    .header-utility__contact::-webkit-scrollbar {
      display: none;
    }
  }

  @media screen and (max-width: 749px) {
    .header-utility {
      font-size: 0.75rem;
    }

    .header-utility__item,
    .header-utility__meta-item {
      min-height: 34px;
      white-space: nowrap;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Fila utilitaria cabecera",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Ancho de sección",
      "options": [
        {
          "value": "page-width",
          "label": "Ancho de página"
        },
        {
          "value": "full-width",
          "label": "Ancho completo"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Espaciado entre elementos",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "text",
      "id": "email_text",
      "label": "Texto de correo",
      "default": "hola@nutriusaimportaciones.com"
    },
    {
      "type": "url",
      "id": "email_link",
      "label": "Enlace de correo"
    },
    {
      "type": "text",
      "id": "phone_text",
      "label": "Texto de teléfono",
      "default": "+51 987 654 321"
    },
    {
      "type": "url",
      "id": "phone_link",
      "label": "Enlace de teléfono"
    },
    {
      "type": "text",
      "id": "locale_text",
      "label": "Texto moneda/idioma",
      "default": "Español (PEN S/)"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Superior",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Inferior",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "support_link",
      "name": "Enlace de soporte",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Texto",
          "default": "Ayuda y soporte"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fila utilitaria cabecera",
      "blocks": {
        "link_1": {
          "type": "support_link",
          "settings": {
            "label": "Devoluciones y cambios"
          }
        },
        "link_2": {
          "type": "support_link",
          "settings": {
            "label": "Preguntas frecuentes"
          }
        },
        "link_3": {
          "type": "support_link",
          "settings": {
            "label": "Rastrea tu pedido"
          }
        },
        "link_4": {
          "type": "support_link",
          "settings": {
            "label": "Centro de soporte"
          }
        }
      },
      "block_order": ["link_1", "link_2", "link_3", "link_4"]
    }
  ]
}
{% endschema %}
