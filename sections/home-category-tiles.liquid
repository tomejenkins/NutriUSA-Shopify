<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="home-category-tiles section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-padding', settings: section.settings %};"
  aria-label="{{ section.settings.section_label }}"
>
  <div class="home-category-tiles__track" role="list">
    {% for block in section.blocks %}
      {% liquid
        assign category_collection = block.settings.collection
        assign tile_title = block.settings.title
        assign tile_subtext = block.settings.subtext
        assign tile_link = block.settings.link

        if category_collection != blank
          if tile_title == blank
            assign tile_title = category_collection.title
          endif

          if block.settings.use_collection_count
            assign tile_subtext = category_collection.products_count | append: ' productos'
          endif

          if tile_link == blank
            assign tile_link = category_collection.url
          endif
        endif
      %}

      {% if tile_title != blank %}
        <article class="home-category-tiles__item" role="listitem" {{ block.shopify_attributes }}>
          {% if tile_link != blank %}
            <a href="{{ tile_link }}" class="home-category-tiles__link" aria-label="{{ tile_title }}">
          {% else %}
            <div class="home-category-tiles__link">
          {% endif %}
              <div class="home-category-tiles__text-wrap">
                <h3 class="home-category-tiles__title">{{ tile_title }}</h3>
                {% if tile_subtext != blank %}
                  <p class="home-category-tiles__subtext">{{ tile_subtext }}</p>
                {% endif %}
              </div>

              <div class="home-category-tiles__media-wrap">
                {% if block.settings.media_type == 'icon' %}
                  <span class="svg-wrapper home-category-tiles__icon">
                    {{ block.settings.icon_asset | default: 'icon-inventory.svg' | inline_asset_content }}
                  </span>
                {% elsif block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 96
                    | image_tag:
                      widths: '40, 64, 80, 96',
                      sizes: '56px',
                      class: 'home-category-tiles__image',
                      alt: tile_title
                  }}
                {% elsif category_collection != blank and category_collection.image != blank %}
                  {{
                    category_collection.image
                    | image_url: width: 96
                    | image_tag:
                      widths: '40, 64, 80, 96',
                      sizes: '56px',
                      class: 'home-category-tiles__image',
                      alt: tile_title
                  }}
                {% else %}
                  <span class="svg-wrapper home-category-tiles__icon">
                    {{ 'icon-inventory.svg' | inline_asset_content }}
                  </span>
                {% endif %}
              </div>
          {% if tile_link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </article>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .home-category-tiles__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(220px, 1fr);
    gap: 0.75rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
    scrollbar-width: none;
  }

  .home-category-tiles__track::-webkit-scrollbar {
    display: none;
  }

  .home-category-tiles__item {
    min-width: 0;
  }

  .home-category-tiles__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    min-height: 80px;
    border-radius: 0.85rem;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    background: rgb(var(--color-foreground-rgb) / 0.03);
    padding: 0.75rem 0.85rem;
    text-decoration: none;
    color: var(--color-foreground);
  }

  .home-category-tiles__title {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.2;
  }

  .home-category-tiles__subtext {
    margin: 0.3rem 0 0;
    font-size: 0.875rem;
    opacity: 0.72;
  }

  .home-category-tiles__media-wrap {
    width: 56px;
    height: 56px;
    border-radius: 0.7rem;
    background: rgb(var(--color-background-rgb) / 0.9);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .home-category-tiles__image {
    width: 80%;
    height: 80%;
    object-fit: contain;
  }

  .home-category-tiles__icon {
    width: 24px;
    height: 24px;
  }

  .home-category-tiles__icon svg {
    width: 100%;
    height: 100%;
  }

  @media screen and (min-width: 990px) {
    .home-category-tiles__track {
      grid-auto-columns: minmax(180px, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Fila de categorías",
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Etiqueta accesible",
      "default": "Categorías destacadas"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Ancho de sección",
      "options": [
        { "value": "page-width", "label": "Ancho de página" },
        { "value": "full-width", "label": "Ancho completo" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Superior",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Inferior",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "category_tile",
      "name": "Tile de categoría",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Colección (opcional)"
        },
        {
          "type": "checkbox",
          "id": "use_collection_count",
          "label": "Usar cantidad de productos de la colección",
          "default": true,
          "visible_if": "{{ block.settings.collection != blank }}"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "info": "Si eliges colección y dejas vacío, se usa el título de la colección."
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtexto",
          "default": "12 productos",
          "info": "Se usa como placeholder manual cuando no hay colección o cuando desactivas el conteo automático."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace",
          "info": "Si eliges colección y dejas vacío, se usa la URL de la colección."
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Tipo de media",
          "options": [
            { "value": "image", "label": "Imagen" },
            { "value": "icon", "label": "Ícono" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen",
          "visible_if": "{{ block.settings.media_type == 'image' }}"
        },
        {
          "type": "select",
          "id": "icon_asset",
          "label": "Ícono",
          "visible_if": "{{ block.settings.media_type == 'icon' }}",
          "options": [
            { "value": "icon-inventory.svg", "label": "Inventario" },
            { "value": "icon-cart.svg", "label": "Carrito" },
            { "value": "icon-discount.svg", "label": "Descuento" },
            { "value": "icon-info.svg", "label": "Información" },
            { "value": "icon-orders.svg", "label": "Pedidos" }
          ],
          "default": "icon-inventory.svg"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fila de categorías",
      "blocks": {
        "tile_1": {
          "type": "category_tile",
          "settings": {
            "title": "Vitaminas",
            "subtext": "24 productos",
            "media_type": "icon",
            "icon_asset": "icon-inventory.svg"
          }
        },
        "tile_2": {
          "type": "category_tile",
          "settings": {
            "title": "Proteínas",
            "subtext": "18 productos",
            "media_type": "icon",
            "icon_asset": "icon-cart.svg"
          }
        },
        "tile_3": {
          "type": "category_tile",
          "settings": {
            "title": "Suplementos",
            "subtext": "30 productos",
            "media_type": "icon",
            "icon_asset": "icon-discount.svg"
          }
        }
      },
      "block_order": ["tile_1", "tile_2", "tile_3"]
    }
  ]
}
{% endschema %}
